# ============================================================
# SMART EXPENSE TRACKER - BACKEND ENVIRONMENT VARIABLES
# ============================================================
# Copy this file to .env and fill in your values
# HOW TO FIND THESE:
#   1. Go to https://supabase.com/dashboard
#   2. Open your project
#   3. Go to Settings → Database
#   4. Copy the "Connection string" (URI format) → DB_URL
#   5. Go to Settings → API
#   6. Copy "Project URL"          → SUPABASE_URL
#   7. Copy "service_role" secret  → SUPABASE_SERVICE_ROLE_KEY
# ============================================================

# --- Server ---
PORT=5000

# --- PostgreSQL Direct Connection (from Supabase → Settings → Database) ---
# Use the "URI" format connection string
# It looks like: postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres
DB_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres

# --- Supabase (for verifying user JWT tokens) ---
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# --- Frontend URL (for CORS) ---
FRONTEND_URL=http://localhost:8080
